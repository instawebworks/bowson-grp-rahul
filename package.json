{
  "name": "bowson-grp",
  "version": "0.1.0",
  "private": true,
  "description": "Bowson GRP production management — full rebuild of t-card.html",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/*\" dev",
    "dev:api": "pnpm --filter @bowson/api dev",
    "dev:web": "pnpm --filter @bowson/web dev",
    "build": "pnpm --filter @bowson/shared build && pnpm --filter @bowson/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0"
}
