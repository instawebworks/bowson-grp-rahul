# ---------------------------------------------------------------------------
# Bowson GRP — environment variables
# Copy this file to ".env" and fill in the values from your Supabase project.
# All values come from the Supabase dashboard → Project Settings → API.
# (No database connection strings are needed — data access goes through the
#  Supabase client.)
# ---------------------------------------------------------------------------

# --- Supabase (backend) -----------------------------------------------------
# Project URL, e.g. https://abcdefghijklmno.supabase.co  (Settings → API → Project URL)
SUPABASE_URL=
# Service role key — SERVER ONLY, never ship to the browser.
# (Settings → API → Project API keys → service_role / secret)
SUPABASE_SERVICE_ROLE_KEY=
# Public anon key (Settings → API → Project API keys → anon / public)
SUPABASE_ANON_KEY=
# JWT secret — signs/verifies the PIN-login tokens (Settings → API → JWT Settings → JWT Secret)
SUPABASE_JWT_SECRET=

# Direct Postgres connection — ONLY used by the one-time `pnpm --filter @bowson/api db:setup`
# script to create tables + seed. The running app does NOT use this (it uses the
# Supabase client above). Format: postgresql://postgres:PASSWORD@HOST:5432/postgres
DATABASE_URL=

# --- API server -------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated list of allowed web origins for CORS.
CORS_ORIGIN=http://localhost:5173
# Set to "true" to require a valid login token on all /api routes.
# Sign-in is PIN-based (manager PIN 1234 by default; operatives get PINs from
# the manager) — no user accounts needed. Requires SUPABASE_JWT_SECRET.
AUTH_REQUIRED=false

# --- Web client (Vite) ------------------------------------------------------
# Read by Vite at build time; must be prefixed with VITE_.
VITE_API_URL=http://localhost:4000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Set to "true" to show the PIN sign-in screen in the web app (must match AUTH_REQUIRED).
VITE_REQUIRE_AUTH=false
