# Bowson GRP — Web (React + Vite) built to static files, served by nginx.
# VITE_* values are baked in at build time, so pass them as build args.
FROM node:20-slim AS build

ENV CI=true
RUN corepack enable
WORKDIR /app

# Build-time config (Vite inlines VITE_* into the bundle).
ARG VITE_API_URL
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY
ARG VITE_REQUIRE_AUTH=false
ENV VITE_API_URL=$VITE_API_URL \
    VITE_SUPABASE_URL=$VITE_SUPABASE_URL \
    VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY \
    VITE_REQUIRE_AUTH=$VITE_REQUIRE_AUTH

COPY . .
RUN pnpm install --frozen-lockfile --filter @bowson/web...
RUN pnpm --filter @bowson/web build

# ── Serve ───────────────────────────────────────────────────────────────────
FROM nginx:alpine
COPY --from=build /app/packages/web/dist /usr/share/nginx/html
COPY packages/web/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
